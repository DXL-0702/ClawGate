# ClawGate 环境变量模板
#
# 使用方式：
#   cp .env.example .env
#   编辑 .env 填入实际值
#   docker compose -f docker-compose.prod.yml up -d
#
# Docker Compose 会自动加载同目录下的 .env 文件。

# ─── 运行模式 ─────────────────────────────────────────────────
# 若主机未安装 OpenClaw，保持 false（默认）。服务将以独立模式运行，
# 仍可使用智能路由、/v1/chat/completions、统计 Dashboard 等核心能力。
# 只有 Agent 管理、Session 监控、DAG 工作流需要连接到 OpenClaw。
CLAWGATE_REQUIRE_OPENCLAW=false

# ─── Provider API Keys（至少配置一个即可使用外部模型） ─────────
# Anthropic Claude：https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI：https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 未配置任何 Provider Key 时，仅本地 Ollama 模型可用（免费但能力受限）。

# ─── 智能路由可选配置 ────────────────────────────────────────
# 简单任务默认模型（本地 Ollama，建议 qwen2.5:3b 最小占用 1.9GB）
# SIMPLE_MODEL=qwen2.5:3b

# 复杂任务默认模型（付费 Provider）
# COMPLEX_MODEL=claude-sonnet-4-6

# ─── 熔断器调优 ──────────────────────────────────────────────
# Provider 失败几次后熔断（默认 5）
# CIRCUIT_FAILURE_THRESHOLD=5

# 熔断冷却时间，秒（默认 30）
# CIRCUIT_RESET_TIMEOUT_SECS=30

# ─── 内存受限机器（< 8GB） ───────────────────────────────────
# 若部署机器内存紧张，可取消注释下面两行跳过 Ollama 预热
# 并手动后续 `docker exec clawgate-ollama ollama pull <model>`
# COMPOSE_PROFILES=minimal
