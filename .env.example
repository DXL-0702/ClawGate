# ClawGate 环境变量模板
#
# 使用方式：
#   cp .env.example .env
#   编辑 .env 填入实际值
#   docker compose -f docker-compose.prod.yml up -d
#
# Docker Compose 会自动加载同目录下的 .env 文件。

# ─── OpenClaw 连接（可选）─────────────────────────────────────
# OpenClaw 是可选依赖。不安装时，ClawGate 以「独立模式」运行，
# 智能路由、Stats Dashboard、/v1/chat/completions 完全可用。
# 安装后，DAG 工作流、Agent 管理、Session 监控功能解锁。
#
# 若主机已安装 OpenClaw（https://github.com/openclaw/openclaw），
# 取消下面注释并配置正确地址，使容器内可访问宿主机 Gateway：
# GATEWAY_URL=ws://host.docker.internal:18789   # macOS/Windows
# GATEWAY_URL=ws://192.168.x.x:18789            # Linux（宿主机实际 IP）
#
# 是否强制要求 OpenClaw（默认 false）。设为 true 时，若 OpenClaw 不可达
# 容器将退出，适用于纯 OpenClaw 生态场景。
CLAWGATE_REQUIRE_OPENCLAW=false
#
# ─── Gateway 认证模式（分层安全策略）───────────────────────────
# 开发环境（本地）：token        → 简单快速，Bearer Token 认证
# 生产环境（团队）：challenge   → 设备签名认证，可吊销，更安全
# 自动检测（默认）：auto        → 有 device.json 时用 challenge，否则 token
# GATEWAY_AUTH_MODE=token

# ─── Provider API Keys（至少配置一个即可使用外部模型） ─────────
# Anthropic Claude：https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI：https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 未配置任何 Provider Key 时，仅本地 Ollama 模型可用（免费但能力受限）。

# ─── 智能路由可选配置 ────────────────────────────────────────
# 简单任务默认模型（本地 Ollama，建议 qwen2.5:3b 最小占用 1.9GB）
# SIMPLE_MODEL=qwen2.5:3b

# 复杂任务默认模型（付费 Provider）
# COMPLEX_MODEL=claude-sonnet-4-6

# ─── 熔断器调优 ──────────────────────────────────────────────
# Provider 失败几次后熔断（默认 5）
# CIRCUIT_FAILURE_THRESHOLD=5

# 熔断冷却时间，秒（默认 30）
# CIRCUIT_RESET_TIMEOUT_SECS=30

# ─── 内存受限机器（< 8GB） ───────────────────────────────────
# 若部署机器内存紧张，可取消注释下面两行跳过 Ollama 预热
# 并手动后续 `docker exec clawgate-ollama ollama pull <model>`
# COMPOSE_PROFILES=minimal
